TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# ID администраторов через запятую (узнать: @userinfobot)
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321

POSTGRES_USER=lombard
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=lombard
DATABASE_URL=postgresql+asyncpg://lombard:change_me_strong_password@postgres:5432/lombard

SITE_BASE_URL=https://lombard-perspectiva.ru
REQUEST_DELAY_SECONDS=1.5
HTTP_TIMEOUT_SECONDS=120
HTTP_MAX_RETRIES=3
# Если прямые запросы падают по таймауту — запасной вариант через прокси:
# HTTP_PROXY=http://user:pass@host:port

# Расписание отчётов (Europe/Moscow)
REPORT_DAILY_HOUR=9
REPORT_WEEKLY_DAY=0
REPORT_MONTHLY_DAY=1
TIMEZONE=Europe/Moscow
